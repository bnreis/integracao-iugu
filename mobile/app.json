        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a56db"
      },
      "package": "com.megasuporte.iugonfse",
      "versionCode": 5
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "0ff0bfeb-796b-430e-a8ff-54b814ed9d2b"
      }
    }
  }
}
