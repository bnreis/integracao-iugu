{
  "expo": {
    "name": "Iugu NFS-e",
    "slug": "iugu-nfse-app",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a56db"
    },
    "android": {
